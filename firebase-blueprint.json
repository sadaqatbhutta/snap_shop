{
  "entities": {
    "Business": {
      "title": "Business",
      "description": "A business tenant using SnapShop AI.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the business." },
        "description": { "type": "string", "description": "A brief description of the business." },
        "aiContext": { "type": "string", "description": "The context provided to the AI for this business." },
        "faqs": { "type": "array", "items": { "type": "string" }, "description": "Frequently asked questions for the business." },
        "ownerEmail": { "type": "string", "format": "email", "description": "The email of the business owner." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the business was created." }
      },
      "required": ["name", "ownerEmail", "createdAt"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A customer of a business.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The customer's name." },
        "channel": { "type": "string", "enum": ["whatsapp", "instagram", "facebook", "webchat"], "description": "The communication channel." },
        "externalId": { "type": "string", "description": "The phone number or social ID of the customer." },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Tags assigned to the customer." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the customer was first recorded." },
        "lastInteractionAt": { "type": "string", "format": "date-time", "description": "When the customer last interacted." }
      },
      "required": ["name", "channel", "externalId", "createdAt"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A chat session between a business and a customer.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string", "description": "The ID of the customer." },
        "status": { "type": "string", "enum": ["active", "human_escalated", "closed"], "description": "The current status of the conversation." },
        "assignedAgentId": { "type": "string", "description": "The ID of the agent assigned to this conversation." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the conversation started." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the conversation was last updated." }
      },
      "required": ["customerId", "status", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a conversation.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string", "description": "The ID of the sender (customer, agent, or 'ai')." },
        "senderType": { "type": "string", "enum": ["customer", "agent", "ai"], "description": "The type of sender." },
        "content": { "type": "string", "description": "The content of the message." },
        "type": { "type": "string", "enum": ["text", "image", "voice"], "description": "The type of message content." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent." }
      },
      "required": ["senderId", "senderType", "content", "type", "timestamp"]
    },
    "Agent": {
      "title": "Agent",
      "description": "A human agent for a business.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The agent's name." },
        "email": { "type": "string", "format": "email", "description": "The agent's email." },
        "role": { "type": "string", "enum": ["admin", "agent"], "description": "The agent's role." }
      },
      "required": ["name", "email", "role"]
    },
    "Segment": {
      "title": "Segment",
      "description": "A group of customers based on criteria.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the segment." },
        "description": { "type": "string", "description": "A description of the segment." },
        "criteria": { "type": "object", "description": "The criteria for the segment (e.g., tags, channel)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the segment was created." }
      },
      "required": ["name", "criteria", "createdAt"]
    },
    "Template": {
      "title": "Template",
      "description": "A message template for broadcasts.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the template." },
        "content": { "type": "string", "description": "The content of the template." },
        "type": { "type": "string", "enum": ["text", "image"], "description": "The type of template." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the template was created." }
      },
      "required": ["name", "content", "type", "createdAt"]
    },
    "Broadcast": {
      "title": "Broadcast",
      "description": "A broadcast message sent to a segment.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the broadcast." },
        "templateId": { "type": "string", "description": "The ID of the template used." },
        "segmentId": { "type": "string", "description": "The ID of the segment targeted." },
        "status": { "type": "string", "enum": ["draft", "scheduled", "sending", "sent", "failed"], "description": "The status of the broadcast." },
        "scheduledAt": { "type": "string", "format": "date-time", "description": "When the broadcast is scheduled to be sent." },
        "sentAt": { "type": "string", "format": "date-time", "description": "When the broadcast was actually sent." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the broadcast was created." }
      },
      "required": ["name", "templateId", "segmentId", "status", "createdAt"]
    }
  },
  "firestore": {
    "/businesses/{businessId}": {
      "schema": "Business",
      "description": "Business tenant data."
    },
    "/businesses/{businessId}/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customers of the business."
    },
    "/businesses/{businessId}/conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Conversations between the business and its customers."
    },
    "/businesses/{businessId}/conversations/{conversationId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a conversation."
    },
    "/businesses/{businessId}/agents/{agentId}": {
      "schema": "Agent",
      "description": "Human agents for the business."
    },
    "/businesses/{businessId}/segments/{segmentId}": {
      "schema": "Segment",
      "description": "Customer segments for the business."
    },
    "/businesses/{businessId}/templates/{templateId}": {
      "schema": "Template",
      "description": "Message templates for the business."
    },
    "/businesses/{businessId}/broadcasts/{broadcastId}": {
      "schema": "Broadcast",
      "description": "Broadcast messages for the business."
    }
  }
}
