# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3040
NODE_ENV=development

# ─── Security ─────────────────────────────────────────────────────────────────
# Required: 32+ character string to verify webhook signatures securely
WEBHOOK_SECRET=your_secret_here_must_be_thirty_two_chars
# Meta Verification Token (set in Meta Developer Portal)
WEBHOOK_VERIFY_TOKEN=your_meta_verification_token
# WhatsApp Phone Number ID (from WhatsApp Business display)
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
# Meta Access Token (System User Token with messaging permissions)
META_ACCESS_TOKEN=your_meta_access_token
# TikTok Access Token (used for outbound TikTok replies)
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token
# TikTok API base URL and send path (optional override)
TIKTOK_API_BASE=https://open.tiktokapis.com/v2
TIKTOK_SEND_PATH=/message/send/
# TikTok webhook signature secret (for inbound verification)
TIKTOK_WEBHOOK_SECRET=your_tiktok_webhook_secret

# ─── AI ───────────────────────────────────────────────────────────────────────
# Required: Your Google Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Redis (BullMQ broker) ────────────────────────────────────────────────────
# IMPORTANT: Requires Redis 6.2+ (BullMQ 5.x requirement)
# Check version: redis-cli INFO server | grep redis_version
#
# Local:           redis://localhost:6379
# With password:   redis://:password@hostname:6379
# With TLS:        rediss://username:password@hostname:6380
# AWS ElastiCache: redis://your-cluster.cache.amazonaws.com:6379
# Google Cloud:    redis://10.0.0.3:6379
REDIS_URL=redis://localhost:6379

# ─── EMR API ──────────────────────────────────────────────────────────────────
EMR_API_URL=https://api.emr.example.com
EMR_API_KEY=your_emr_api_key_here
EMR_TIMEOUT_MS=10000

# ─── Queue ────────────────────────────────────────────────────────────────────
QUEUE_CONCURRENCY=5
QUEUE_MAX_RETRIES=3
# Local development default:
QUEUE_STRICT_MODE=false
# Staging/production recommended value:
# QUEUE_STRICT_MODE=true

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQ=60
RATE_LIMIT_AI_MAX_REQ=30
RATE_LIMIT_EMR_MAX_REQ=10

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://snapshop-2bd87.web.app
SMTP_API_URL=https://api.sendgrid.com/v3/mail/send

# ─── Firebase Frontend (Vite) ─────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=snapshop-2bd87.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=snapshop-2bd87
VITE_FIREBASE_STORAGE_BUCKET=snapshop-2bd87.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=821516476451
VITE_FIREBASE_APP_ID=1:821516476451:web:86d6cab7fa8bc99d051196
VITE_FIREBASE_FIRESTORE_DATABASE_ID=snapshop-2bd87-service
